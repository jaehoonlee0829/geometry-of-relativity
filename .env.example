# Copy to .env and fill in your tokens. .env is gitignored — never commit it.

# Hugging Face. Required for:
#   - downloading google/gemma-2-2b (gated; accept license at
#     https://huggingface.co/google/gemma-2-2b first)
#   - downloading google/gemma-scope-2b-pt-res (Gemma Scope SAEs, P3)
#   - fetching activations from xrong1729/mech-interp-relativity-activations
#     via scripts/fetch_from_hf.py
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# Weights & Biases. OPTIONAL. If unset, scripts skip wandb cleanly.
# Gives a UI for tracking R²(z), entropy, steering slopes per run.
WANDB_API_KEY=

# GitHub PAT. Only needed if you want to `git push` from inside this checkout
# without a separate auth setup.
GH_TOKEN=
GITHUB_TOKEN=
